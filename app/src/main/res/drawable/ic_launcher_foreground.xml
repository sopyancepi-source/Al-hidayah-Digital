<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer Decorative circular border -->
    <path
        android:pathData="M 54,16 A 38,38 0 1,1 53.99,16"
        android:strokeWidth="1.5"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFE082" />
                <item android:offset="1.0" android:color="#FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Crescent Moon -->
    <path
        android:pathData="M 54,26 A 28,28 0 1,0 82,54 A 23,23 0 1,1 54,26 Z"
        android:strokeWidth="1">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFE082" />
                <item android:offset="1.0" android:color="#FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Star -->
    <path
        android:pathData="M 68,32 L 70.35,36.76 L 75.6,37.52 L 71.8,41.22 L 72.7,46.45 L 68,44 L 63.3,46.45 L 64.2,41.22 L 60.4,37.52 L 65.65,36.76 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFE082" />
                <item android:offset="1.0" android:color="#FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Open Book (Quran Pages) -->
    <path
        android:pathData="M 54,64 C 50,60 42,60 36,62 L 36,74 C 42,72 50,72 54,76 C 58,72 66,72 72,74 L 72,62 C 66,60 58,60 54,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFE082" />
                <item android:offset="1.0" android:color="#FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Book Stand (Rehal) -->
    <path
        android:pathData="M 42,76 L 48,82 L 60,82 L 66,76 L 62,76 L 54,80 L 46,76 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFE082" />
                <item android:offset="1.0" android:color="#FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
